{
  "name": "backdrop",
  "private": true,
  "homepage": "https://github.com/aensley/backdrop#readme",
  "bugs": {
    "url": "https://github.com/aensley/backdrop/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aensley/backdrop.git"
  },
  "license": "MIT",
  "scripts": {
    "commit": "czg",
    "lint": "prettier --check .",
    "lint:fix": "prettier --write .",
    "prepare": "npx simple-git-hooks",
    "update": "npx npm-check-updates -u && npm update"
  },
  "devDependencies": {
    "czg": "^1.13.1",
    "prettier": "^3.8.3",
    "prettier-plugin-sh": "^0.18.1",
    "simple-git-hooks": "^2.13.1"
  },
  "allowScripts": {
    "simple-git-hooks@2.13.1": true
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      [
        "@semantic-release/release-notes-generator",
        {
          "preset": "conventionalcommits"
        }
      ],
      "@semantic-release/github"
    ]
  },
  "prettier": {
    "tabWidth": 2,
    "printWidth": 120,
    "useTabs": false,
    "endOfLine": "lf",
    "trailingComma": "none",
    "semi": false,
    "singleQuote": true,
    "arrowParens": "always",
    "bracketSameLine": true,
    "bracketSpacing": true,
    "embeddedLanguageFormatting": "auto",
    "htmlWhitespaceSensitivity": "css",
    "insertPragma": false,
    "jsxSingleQuote": false,
    "proseWrap": "preserve",
    "quoteProps": "as-needed",
    "requirePragma": false,
    "vueIndentScriptAndStyle": false,
    "plugins": [
      "prettier-plugin-sh"
    ],
    "overrides": [
      {
        "files": [
          "*.sh",
          "*.bash"
        ],
        "options": {
          "parser": "sh"
        }
      }
    ]
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git",
      "type": "conventional",
      "useEmoji": true
    }
  },
  "simple-git-hooks": {
    "pre-commit": "npm run lint",
    "prepare-commit-msg": "exec < /dev/tty && node_modules/.bin/czg --hook \"$1\" \"$2\" || true"
  }
}
