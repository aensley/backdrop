{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "backdrop",
  "version": "1.3.0",
  "identifier": "com.andrewensley.backdrop",
  "build": {
    "frontendDist": "../frontend",
    "beforeDevCommand": "node scripts/dev-setup.js"
  },
  "app": {
    "withGlobalTauri": true,
    "enableGTKAppId": true,
    "windows": [
      {
        "title": "backdrop",
        "width": 690,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDczMkRDNkM0QUQyNjBDRjcKUldUM0RDYXR4TVl0YzM2MVpiS2h5a2JRcXZ3ZUE2SUhmcm9NS3N2eGdiaUVkc0hZQUhKSlYzdksK",
      "endpoints": [""]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
